<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="project_controller.BarbeiroListaController"
            prefHeight="400" prefWidth="600">

    <top>
        <Label text="Lista de Barbeiros" BorderPane.alignment="CENTER"
               style="-fx-font-size: 18px; -fx-padding: 10px; -fx-font-weight: bold;" />
    </top>

    <center>
        <TableView fx:id="tabelaBarbeiros">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colNome" text="Nome" prefWidth="200"/>
                <TableColumn fx:id="colEspecialidade" text="Especialidade" prefWidth="150"/>
                <TableColumn fx:id="colTelefone" text="Telefone" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <Button text="Voltar" onAction="#voltar"
                style="-fx-background-color: darkred; -fx-text-fill: white;"
                BorderPane.alignment="CENTER" />
    </bottom>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="project_controller.AgendamentoController"
            prefHeight="720" prefWidth="1080">

    <center>
        <VBox alignment="CENTER" spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="40" />
            </padding>

            <Label text="--- MENU AGENDAMENTOS ---"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <Button text="Incluir Agendamento" onAction="#incluirAgendamento" prefWidth="200" />
            <Button text="Excluir Agendamento" onAction="#excluirAgendamento" prefWidth="200" />
            <Button text="Listar Agendamentos" onAction="#listarAgendamentos" prefWidth="200" />
            <Button text="Pesquisar por Cliente" onAction="#pesquisarPorCliente" prefWidth="200" />
            <Button text="Pesquisar por Barbeiro" onAction="#pesquisarPorBarbeiro" prefWidth="200" />
            
             <Button text="Voltar ao Menu" onAction="#voltar" prefWidth="300"
                    style="-fx-background-color: darkred; -fx-text-fill: white;" />
        </VBox>
    </center>

</BorderPane>

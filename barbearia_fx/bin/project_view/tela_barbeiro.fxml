<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720" prefWidth="1080" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project_controller.BarbeiroController">

    <children>
        <VBox alignment="CENTER" layoutX="237.0" layoutY="114.0" prefHeight="461.0" prefWidth="606.0" spacing="15">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Tela de Barbeiros" />

            <Button onAction="#incluirBarbeiro" prefWidth="200" text="Incluir Barbeiro" />
            <Button onAction="#excluirBarbeiro" prefWidth="200" text="Excluir Barbeiro" />
            <Button onAction="#listarBarbeiros" prefWidth="200" text="Listar Barbeiros" />
            <Button onAction="#listarAgendamentosBarbeiros" prefWidth="250" text="Lista de Agendamento de Barbeiros" />

            <Button onAction="#voltar" prefWidth="200" style="-fx-background-color: darkred; -fx-text-fill: white;" text="Voltar ao Menu" />
        </VBox>
    </children>
</AnchorPane>
